# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/

# Editors
.vscode/
.idea/

# PyInstaller work cache (the SHIPPED exe lives in dist/ and IS tracked)
build/

# Generated data / runtime logs (not source)
output/
samples/
*.log

# Test scratch dirs (regenerated by the test suite)
tests/_tmp_*/

# reconvert scratch output (never committed)
_tmp_regen/
_tmp_regen*/

# Per-run failure record (written every run next to the run log)
CBBEtoUBE_last_failures.json

# Packaged release archives
CBBEtoUBE-*.zip
